# --- Database ---
DATABASE_URL="postgresql://november:november@localhost:5432/november_trip?schema=public"
# Only different from DATABASE_URL on serverless Postgres providers (Neon,
# Supabase, Vercel Postgres) that give you a separate pooled vs. direct
# connection string. For a normal Postgres instance, just copy the same
# value as DATABASE_URL - Prisma requires this variable to exist.
DIRECT_URL="postgresql://november:november@localhost:5432/november_trip?schema=public"

# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Auth ---
# Generate a strong random value, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# --- Odoo webhook (Odoo -> app, real-time) ---
# Generate a random value and put the same one in the Odoo Automation Rule
# request header `X-Webhook-Secret`. Leave unset to disable the endpoint.
ODOO_WEBHOOK_SECRET=change-me-too

# --- File storage (optional - only needed for Vercel or large image volumes) ---
# Leave everything below unset to use local disk (Docker/VPS default).
#
# Option A: S3-compatible storage (Cloudflare R2, AWS S3, Backblaze B2...).
# Takes priority over Vercel Blob if both are set. Recommended for storing
# a lot of images - R2 in particular has no egress fees.
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=november-trip-uploads
# S3_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
# S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# S3_REGION=auto
# S3_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
#
# Option B: Vercel Blob (only used if Option A is not set). Auto-populated
# by Vercel when you connect a Blob store to the project - you shouldn't
# need to set this by hand.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Odoo (optional: can also be set via the in-app Odoo Sync Settings page) ---
# ODOO_URL=https://yourcompany.odoo.com
# ODOO_DB=yourcompany
# ODOO_USERNAME=api@yourcompany.com
# ODOO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# ODOO_MODEL_MAP={"HotelSupplier":"res.partner","TourSupplier":"res.partner","Product":"product.template","Quotation":"sale.order"}
